{
  "name": "@oorjaman/mobile-config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Expo config plugins, Metro config, and native rebuild scripts for customer-app and technician-app.",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./metro": {
      "types": "./metro.d.ts",
      "default": "./metro.js"
    },
    "./shared-plugins": {
      "types": "./shared-plugins.d.ts",
      "default": "./shared-plugins.js"
    }
  },
  "scripts": {
    "typecheck": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@expo/image-utils": "~0.7.0"
  }
}
