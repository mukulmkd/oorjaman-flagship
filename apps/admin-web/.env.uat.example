# UAT builds (Vercel / dev-admin hostnames). Copy to .env.uat.local (gitignored).
# Loaded by `npm run build:uat -w admin-web` (Vite mode `uat`).
# For local Metro-style dev on localhost ports, use .env.development.local instead.

VITE_DEPLOY_ENV=uat
VITE_SUPABASE_URL=https://YOUR_UAT_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_uat_anon_key

# Deployed UAT portal URLs (Vercel or dev-*.oorjaman.com — not localhost)
VITE_ADMIN_PORTAL_URL=https://oorjaman-admin.vercel.app
VITE_VENDOR_PORTAL_URL=https://oorjaman-vendor.vercel.app
VITE_SUPPORT_PORTAL_URL=https://oorjaman-support.vercel.app

VITE_USE_DUMMY_AUTH=true
VITE_DUMMY_OTP_CODE=123456
VITE_DUMMY_AUTH_PASSWORD=TestOtp123!
