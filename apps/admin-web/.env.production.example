# GoDaddy / prod builds only. Copy to .env.production.local (gitignored).
# Loaded automatically by `npm run build -w admin-web`.

VITE_DEPLOY_ENV=production
VITE_SUPABASE_URL=https://YOUR_PROD_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_prod_anon_key

VITE_ADMIN_PORTAL_URL=https://admin.oorjaman.com
VITE_VENDOR_PORTAL_URL=https://vendor.oorjaman.com
VITE_SUPPORT_PORTAL_URL=https://support.oorjaman.com

# Do not set VITE_USE_DUMMY_AUTH on production.
