{
  "name": "admin-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run brand:sync && vite --mode development",
    "build": "npm run brand:sync && tsc -b && vite build --mode production",
    "brand:sync": "node ../../scripts/sync-brand-assets.mjs",
    "brand:sync:web": "node ../../scripts/sync-brand-assets.mjs --web-only",
    "build:uat": "npm run brand:sync:web && tsc -b && vite build --mode uat",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint ."
  },
  "dependencies": {
    "@oorjaman/api": "*",
    "@oorjaman/config": "*",
    "@oorjaman/utils": "*",
    "@oorjaman/web-ui": "*",
    "@tanstack/react-query": "^5.90.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
