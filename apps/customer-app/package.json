{
  "name": "customer-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:rebuild": "bash scripts/rebuild-ios.sh",
    "web": "expo start --web",
    "expo:types": "expo customize tsconfig.json",
    "typecheck": "npm run expo:types && tsc --noEmit",
    "lint": "npm run typecheck",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy",
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "brand:sync": "node ../../scripts/sync-brand-assets.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@oorjaman/api": "*",
    "@oorjaman/config": "*",
    "@oorjaman/ui": "*",
    "@oorjaman/utils": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.12",
    "expo": "~54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
