# DEPRECATED — use env/uat.local instead (see env/uat.local.example).
#
# apps/<app>/.env.uat.local in the app root breaks Expo Metro dev: Metro's require.context
# scans ./.env* and tries to parse this file as JavaScript.
#
# UAT native builds:  cp env/uat.local.example env/uat.local
# Local Metro dev:     cp .env.development.example .env.development.local
# Production builds:   cp .env.production.example .env.production.local
