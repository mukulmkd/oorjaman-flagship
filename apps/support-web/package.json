{
  "name": "support-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run brand:sync && vite --mode development",
    "build": "npm run brand:sync && tsc -b && vite build --mode production",
    "brand:sync": "node ../../scripts/sync-brand-assets.mjs",
    "brand:sync:web": "node ../../scripts/sync-brand-assets.mjs --web-only",
    "build:uat": "npm run brand:sync:web && tsc -b && vite build --mode uat",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint ."
  },
  "dependencies": {
    "@oorjaman/portal-deps": "*"
  }
}
