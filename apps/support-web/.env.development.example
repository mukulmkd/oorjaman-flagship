# Local dev on localhost. Copy to .env.development.local (gitignored).
# Vite mode `development`. For Vercel-style URLs use .env.uat.example → .env.uat.local.

VITE_DEPLOY_ENV=uat
VITE_SUPABASE_URL=https://YOUR_UAT_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_uat_anon_key

VITE_ADMIN_PORTAL_URL=http://localhost:5173
VITE_VENDOR_PORTAL_URL=http://localhost:5174
VITE_SUPPORT_PORTAL_URL=http://localhost:5175

VITE_USE_DUMMY_AUTH=true
VITE_DUMMY_OTP_CODE=123456
VITE_DUMMY_AUTH_PASSWORD=TestOtp123!
