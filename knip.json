{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "expo": false,
  "vite": true,
  "ignoreExportsUsedInFile": true,
  "ignore": ["**/*.d.ts"],
  "ignoreIssues": {
    "apps/customer-app/**": ["unlisted"],
    "apps/technician-app/**": ["unlisted"],
    "apps/admin-web/**": ["unlisted"],
    "apps/support-web/**": ["unlisted"],
    "apps/vendor-web/**": ["unlisted"],
    "packages/mobile-deps/**": ["dependencies"],
    "packages/portal-deps/**": ["dependencies"],
    "packages/vite-portal-config/**": ["dependencies", "devDependencies"],
    "packages/mobile-config/**": ["unlisted"],
    "packages/ui/**": ["unlisted"]
  },
  "ignoreBinaries": ["python3", "vite", "eslint", "expo"],
  "ignoreDependencies": ["eslint", "eslint-config-next"],
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{mjs,js}"],
      "project": ["scripts/**/*.{mjs,js}"]
    },
    "apps/customer-app": {
      "entry": ["app/**/*.{ts,tsx}", "app.config.ts"],
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "constants/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": ["@oorjaman/mobile-deps"]
    },
    "apps/technician-app": {
      "entry": ["app/**/*.{ts,tsx}", "app.config.ts"],
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "constants/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": ["@oorjaman/mobile-deps"]
    },
    "apps/admin-web": {
      "entry": ["index.html"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@oorjaman/portal-deps"]
    },
    "apps/support-web": {
      "entry": ["index.html"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@oorjaman/portal-deps"]
    },
    "apps/vendor-web": {
      "entry": ["index.html"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@oorjaman/portal-deps"]
    },
    "apps/oorjaman-web": {
      "entry": ["app/**/*.{ts,tsx}", "next.config.{js,ts,mjs}"],
      "project": ["app/**/*.{ts,tsx}"]
    },
    "packages/api": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/web-ui": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/config": {
      "project": ["src/**/*.ts"]
    },
    "packages/utils": {
      "project": ["src/**/*.ts"]
    },
    "packages/mobile-config": {
      "project": ["index.js", "metro.js", "shared-plugins.js", "plugins/**/*.js", "scripts/**/*.sh"]
    },
    "packages/vite-portal-config": {
      "project": ["src/**/*.ts", "eslint.config.js"]
    },
    "supabase/functions": {
      "entry": ["**/*.ts"],
      "project": ["**/*.ts"]
    }
  }
}
