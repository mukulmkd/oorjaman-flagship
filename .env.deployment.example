# Deployment matrix — copy values into per-app `.env.*.local` files (never commit secrets).
# Full runbook: project-docs/DEPLOYMENT.md, project-docs/VERCEL.md, project-docs/ENVIRONMENT.md

# =============================================================================
# SUPABASE PROJECT REFS
# =============================================================================
SUPABASE_UAT_PROJECT_REF=YOUR_UAT_PROJECT_REF
SUPABASE_PROD_PROJECT_REF=YOUR_PROD_PROJECT_REF

SUPABASE_UAT_URL=https://YOUR_UAT_PROJECT_REF.supabase.co
SUPABASE_PROD_URL=https://YOUR_PROD_PROJECT_REF.supabase.co

# =============================================================================
# REPO ROOT SCRIPTS — copy .env.uat.local.example → .env.uat.local
# =============================================================================
# SUPABASE_URL=${SUPABASE_UAT_URL}
# SUPABASE_SERVICE_ROLE_KEY=<uat_service_role>
# DUMMY_AUTH_PASSWORD=TestOtp123!

# =============================================================================
# VITE PORTALS — three modes per app (admin-web, vendor-web, support-web)
# =============================================================================
# .env.development.local  → localhost:5173–5175, UAT Supabase, dummy auth optional
# .env.uat.local          → Vercel URLs (below) OR dev-*.oorjaman.com when on GoDaddy UAT
# .env.production.local   → admin/vendor/support.oorjaman.com, Prod Supabase, NO dummy auth
#
# Vercel Dashboard (live UAT — set Production + Preview scope on each project):
#   VITE_DEPLOY_ENV=uat
#   VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY → UAT project
#   VITE_ADMIN_PORTAL_URL=https://oorjaman-admin.vercel.app
#   VITE_VENDOR_PORTAL_URL=https://oorjaman-vendor.vercel.app
#   VITE_SUPPORT_PORTAL_URL=https://oorjaman-support.vercel.app
#   VITE_USE_DUMMY_AUTH=true, VITE_DUMMY_OTP_CODE=123456, VITE_DUMMY_AUTH_PASSWORD=TestOtp123!

# =============================================================================
# EXPO MOBILE — .env.development.local (Metro) / env/uat.local (UAT APK & EAS)
# =============================================================================
# EXPO_PUBLIC_DEPLOY_ENV=local | uat | production
# EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY → matching project
# EXPO_PUBLIC_SITE_URL → marketing URL for legal links

# =============================================================================
# NEXT MARKETING — apps/oorjaman-web/.env.development.local | .env.production.local
# =============================================================================
# NEXT_PUBLIC_DEPLOY_ENV=uat | production
# NEXT_PUBLIC_SITE_URL=http://localhost:3000 | https://oorjaman.com | https://dev-oorjaman.oorjaman.com
# NEXT_PUBLIC_VENDOR_PORTAL_URL → Vercel vendor URL (UAT) or vendor.oorjaman.com (prod)
