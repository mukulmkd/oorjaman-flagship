{
  "name": "oorjaman-flagship",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "scripts": {
    "customer": "npm run start -w customer-app",
    "technician": "npm run start -w technician-app",
    "admin": "npm run dev -w admin-web",
    "vendor": "npm run dev -w vendor-web",
    "support": "npm run dev -w support-web",
    "web": "npm run dev -w oorjaman-web",
    "web:godaddy": "npm run build:godaddy -w oorjaman-web",
    "build": "npm run build -w admin-web && npm run build -w vendor-web && npm run build -w support-web && npm run build -w oorjaman-web",
    "build:web": "npm run build -w oorjaman-web",
    "lint": "npm run lint --workspaces --if-present",
    "expo:types": "npm run expo:types -w customer-app && npm run expo:types -w technician-app",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "seed:dummy-users": "node scripts/seed-dummy-test-users.mjs",
    "repair:public-users": "node scripts/repair-public-users.mjs",
    "db:push": "node scripts/supabase-db-push.mjs",
    "db:push:yes": "supabase db push --yes",
    "db:reference": "node scripts/build-supabase-reference.mjs",
    "db:push:include-all": "node scripts/supabase-db-push.mjs --include-all --yes",
    "db:status": "supabase status",
    "supabase": "supabase",
    "functions:deploy": "node scripts/supabase-function-deploy.mjs",
    "typecheck:edge-functions": "tsc -p supabase/functions/tsconfig.json --pretty false"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^16.4.5",
    "supabase": "2.100.0",
    "typescript": "~5.7.2"
  }
}
