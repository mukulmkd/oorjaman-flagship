# Repo-root scripts only (seed, repair, purge). Copy to .env.uat.local (gitignored).
# Default for: npm run seed:dummy-users

SUPABASE_UAT_PROJECT_REF=YOUR_UAT_PROJECT_REF
SUPABASE_PROD_PROJECT_REF=YOUR_PROD_PROJECT_REF

SUPABASE_URL=https://YOUR_UAT_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_uat_service_role_key

DUMMY_AUTH_PASSWORD=TestOtp123!

# Optional — Supabase CLI only (`supabase link`, `db dump`, `db push`):
# SUPABASE_DB_PASSWORD=your_uat_database_password
