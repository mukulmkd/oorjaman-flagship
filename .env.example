# Templates only — never put real API keys in committed files.
# Per app: copy `.env.development.example` → `.env.development.local` (UAT/local)
#          copy `.env.production.example` → `.env.production.local` (prod builds)
# Scripts: copy `.env.uat.local.example` → `.env.uat.local` (repo root)
# See ENVIRONMENT.md and `.env.deployment.example`

# -----------------------------------------------------------------------------
# Supabase (Expo mobile apps - EXPO_PUBLIC_ prefix)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# -----------------------------------------------------------------------------
# Supabase (admin-web + vendor-web + support-web - VITE_ prefix; use the same values in each app .env)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Deploy tier: local | uat | production (web builds - see DEPLOYMENT.md)
# NEXT_PUBLIC_DEPLOY_ENV=production
# VITE_DEPLOY_ENV=production

# Public marketing + legal site (see SEO.md + DEPLOYMENT.md)
# EXPO_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# PROD: https://oorjaman.com
# UAT:  https://dev-oorjaman.oorjaman.com  (+ NEXT_PUBLIC_DEPLOY_ENV=uat for noindex)

# Cross-link web portals (local dev defaults)
# VITE_VENDOR_PORTAL_URL=http://localhost:5174
# VITE_ADMIN_PORTAL_URL=http://localhost:5173
# VITE_SUPPORT_PORTAL_URL=http://localhost:5175
# PROD: https://admin|vendor|support.oorjaman.com
# UAT:  https://dev-admin|dev-vendor|dev-support.oorjaman.com
# Support desk login: users with role `support` (see support_agents table) or `admin`.
# Seed dev agents: +919000000111, +919000000112 (after db push + npm run seed:dummy-users).

# -----------------------------------------------------------------------------
# Dummy OTP / password sign-in (local QA - disable in production)
# Skip real SMS; “Send code” is a no-op; verification uses a fixed OTP then password login.
# Password must match `npm run seed:dummy-users` (see `DUMMY_AUTH_PASSWORD` below).
# Supabase Dashboard → Authentication → Providers: keep Email enabled (dummy sign-in uses email+password).
# -----------------------------------------------------------------------------
EXPO_PUBLIC_USE_DUMMY_AUTH=true
EXPO_PUBLIC_DUMMY_OTP_CODE=123456
EXPO_PUBLIC_DUMMY_AUTH_PASSWORD=TestOtp123!

VITE_USE_DUMMY_AUTH=true
VITE_DUMMY_OTP_CODE=123456
VITE_DUMMY_AUTH_PASSWORD=TestOtp123!

# -----------------------------------------------------------------------------
# Seed script only (repo-root `.env`, never ship to clients - gitignore `.env`)
# SUPABASE_URL same project URL as above
# SUPABASE_SERVICE_ROLE_KEY from Dashboard → Settings → API → service_role
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# DUMMY_AUTH_PASSWORD=TestOtp123!

# -----------------------------------------------------------------------------
# Customer app only - Google Maps (native maps + static fallback; rebuild after change)
# See BILLING.md and ENVIRONMENT.md
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

# -----------------------------------------------------------------------------
# Customer + partner apps - Expo remote push (EAS project UUID; dev/prod builds)
# See ENVIRONMENT.md, docs/customer-push-setup.md, docs/technician-push-setup.md
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# Optional - not used by this codebase today (remove from app `.env` unless you add an HTTP API).
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_API_URL=http://localhost:3001
